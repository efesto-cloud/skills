{
    "name": "{{ns}}/core",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "module": "./dist/server.js",
    "types": "./dist/server.d.ts",
    "exports": {
        ".": {
            "import": "./dist/server.js",
            "types": "./dist/server.d.ts"
        },
        "./*": {
            "import": "./dist/*.js",
            "types": "./dist/*.d.ts"
        },
        "./client": {
            "import": "./dist/client.js",
            "types": "./dist/client.d.ts"
        },
        "./server": {
            "import": "./dist/server.js",
            "types": "./dist/server.d.ts"
        },
        "./global": {
            "types": "./global.d.ts"
        },
        "./env": {
            "types": "./env.d.ts"
        }
    },
    "files": [
        "dist",
        "global.d.ts"
    ],
    "scripts": {
        "clean": "rimraf dist/",
        "prebuild": "pnpm run clean",
        "build": "tsc --build",
        "dev": "tsc --build --watch",
        "typecheck": "tsc --noEmit",
        "postbuild": "tsc-alias",
        "biome": "biome check"
    },
    "peerDependencies": {
        "@efesto-cloud/database-context": "^0.0.2",
        "@efesto-cloud/entity": "^0.0.2",
        "@efesto-cloud/env": "^0.0.2",
        "@efesto-cloud/maybe": "^0.0.2",
        "@efesto-cloud/metadata": "^0.0.2",
        "@efesto-cloud/mongodb-population": "^0.0.2",
        "@efesto-cloud/population": "^0.0.2",
        "@efesto-cloud/result": "^0.0.2",
        "decimal.js": "^10.5.0",
        "inversify": "^6.0.2",
        "luxon": "^3.5.0",
        "phone": "^3.1.50",
        "typeid-js": "^1.2.0",
        "winston": "^3.14.2",
        "zod": "^4"
    },
    "devDependencies": {
        "@types/luxon": "^3",
        "@types/node": "^24",
        "rimraf": "^6.0.1",
        "tsc-alias": "^1.8.16",
        "typescript": "^6"
    }
}
