type Keys =
    | "MONGO_DB_URL_PATH"
    | "ROOT_URL"
    | "LOG_LEVEL"
    | "VERSION"
    | "COOKIE_SECRET_PATH"
    | "BUILD_DATE";

declare module "process" {
    global {
        namespace NodeJS {
            interface ProcessEnv extends Record<Keys, string | undefined> {
                MOCK: "true" | undefined;
                LOG_LEVEL:
                    | "error"
                    | "warn"
                    | "info"
                    | "http"
                    | "verbose"
                    | "debug"
                    | "silly"
                    | undefined;
                NODE_ENV: "development" | "production" | undefined;
            }
        }
    }
}
